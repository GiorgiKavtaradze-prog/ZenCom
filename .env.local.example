# ---- Convex ----
# Created automatically when you run `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Deployment used by `npx convex dev` (auto-filled).
CONVEX_DEPLOYMENT=dev:your-deployment

# ---- Clerk (from dashboard.clerk.com -> API keys) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Where Clerk sends users for auth
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# NOTE: also set CLERK_JWT_ISSUER_DOMAIN in your CONVEX env (not here):
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://your-clerk-subdomain.clerk.accounts.dev
# It must match the "Issuer" of the Clerk JWT template named "convex" (see README).

# ---- Clerk Billing plan ids (Clerk dashboard -> Billing -> Plans) ----
# Used by <CheckoutButton planId=…>
NEXT_PUBLIC_CLERK_PLAN_FREE_ID=cplan_xxx
NEXT_PUBLIC_CLERK_PLAN_PRO_ID=cplan_xxx
NEXT_PUBLIC_CLERK_PLAN_SCALE_ID=cplan_xxx
